{
  "name": "papa-everetts-pizza",
  "version": "1.1.9",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web run build",
    "deploy": "pnpm --filter web run deploy",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "prelint": "pnpm run build:plugins",
    "lint": "pnpm run prelint && pnpm --filter web run lint",
    "typecheck": "pnpm --filter web run typecheck",
    "quality": "turbo run quality --filter='./apps/*'",
    "db:migrate": "pnpm --filter web run db:migrate",
    "db:ready": "pnpm --filter web run db:ready",
    "db:studio": "pnpm --filter web run db:studio",
    "setup": "npx tsx tools/init.ts",
    "update-layer": "npx tsx tools/update-layer.ts",
    "validate": "npx tsx tools/validate.ts",
    "generate:favicons": "npx tsx tools/generate-favicons.ts",
    "test:unit": "pnpm --filter web run test:unit",
    "test:e2e": "pnpm --filter web run test:e2e",
    "predev": "node tools/check-setup.cjs",
    "prebuild": "node tools/check-setup.cjs",
    "predeploy": "node tools/check-setup.cjs",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  Run pnpm run setup before doing anything else! See AGENTS.md.\\n')\""
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3",
      "@cloudflare/unenv-preset": "2.12.1",
      "nuxt-og-image": "6.0.0-beta.47"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "tsx": "^4.0.0"
  }
}
