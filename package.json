{
  "name": "papa-everetts-pizza",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "npm run db:setup:local && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && pnpm run build:plugins",
    "typecheck": "npx nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "build:plugins": "cd eslint-plugin-nuxt-ui && pnpm run build && cd ../eslint-plugin-nuxt-guardrails && pnpm run build && cd ../tools/eslint-plugin-vue-official-best-practices && pnpm run build",
    "prelint": "(test -f .nuxt/eslint.config.mjs || nuxt prepare) && (test -f eslint-plugin-nuxt-ui/dist/index.js || pnpm run build:plugins)",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute papa-everetts-pizza-db --local --file=drizzle/0000_initial_schema.sql",
    "db:setup:local": "yes | wrangler d1 migrations apply papa-everetts-pizza-db --local",
    "db:studio": "drizzle-kit studio",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "setup": "npx jiti tools/setup-analytics.ts status",
    "setup:all": "npx jiti tools/setup-analytics.ts all",
    "setup:posthog": "npx jiti tools/setup-analytics.ts posthog",
    "setup:ga": "npx jiti tools/setup-analytics.ts ga",
    "setup:gsc": "npx jiti tools/setup-analytics.ts gsc",
    "setup:gsc:verify": "npx jiti tools/setup-analytics.ts gsc:verify",
    "init": "npx jiti tools/init.ts",
    "validate": "npx jiti tools/validate.ts"
  },
  "dependencies": {
    "@iconify-json/simple-icons": "^1.2.71",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/seo": "^3.4.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "nuxt": "^4.3.0",
    "posthog-js": "^1.205.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/devicon": "^1.2.59",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.0",
    "@vue/test-utils": "^2.4.6",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "google-auth-library": "^10.6.1",
    "googleapis": "^144.0.0",
    "happy-dom": "^20.7.0",
    "jiti": "^2.6.1",
    "nitro-cloudflare-dev": "^0.2.2",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@latest"
  },
  "volta": {
    "node": "22.14.0"
  }
}
